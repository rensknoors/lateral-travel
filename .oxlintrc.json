{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc",
    "import",
    "react",
    "jsx-a11y",
    "nextjs",
    "vitest"
  ],
  "env": {
    "browser": true,
    "es2024": true,
    "node": true
  },
  "settings": {
    "react": {
      "version": "19.2.4"
    },
    "next": {
      "rootDir": ["."]
    }
  },
  "ignorePatterns": [
    ".next/**",
    "build/**",
    "coverage/**",
    "node_modules/**",
    "out/**",
    "types/**"
  ]
}
