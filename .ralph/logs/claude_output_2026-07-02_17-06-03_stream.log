{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_012hTrgsLwVZkysqgo9C5HM6","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01CahYDdHjkQTnZfyLgHrvpx","name":"Write","input":{"file_path":"/Users/rensknoors/repos/lateral-assessment/components/reviews/review-form.tsx","content":"\"use client\";\n\nimport { useState } from \"react\";\nimport { useForm } from \"react-hook-form\";\nimport { zodResolver } from \"@hookform/resolvers/zod\";\nimport { reviewSchema, ReviewInput } from \"@/lib/schemas/review-schema\";\nimport { Review } from \"@/lib/types\";\nimport { Star, Loader2 } from \"lucide-react\";\n\ninterface ReviewFormProps {\n  hotelId: string;\n  onReviewAdded: (review: Review) => void;\n}\n\nexport function ReviewForm({ hotelId, onReviewAdded }: ReviewFormProps) {\n  const [submitError, setSubmitError] = useState(\"\");\n  const [hoverRating, setHoverRating] = useState(0);\n\n  const {\n    register,\n    handleSubmit,\n    setValue,\n    watch,\n    reset,\n    formState: { errors, isSubmitting },\n  } = useForm<ReviewInput>({\n    resolver: zodResolver(reviewSchema),\n    defaultValues: { rating: 0 },\n  });\n\n  const rating = watch(\"rating\");\n\n  const onSubmit = async (data: ReviewInput) => {\n    setSubmitError(\"\");\n    try {\n      const res = await fetch(`/api/hotels/${hotelId}/reviews`, {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify(data),\n      });\n      if (!res.ok) {\n        const err = await res.json();\n        setSubmitError(err.error ?? \"Failed to submit review\");\n        return;\n      }\n      const review: Review = await res.json();\n      onReviewAdded(review);\n      reset({ rating: 0 });\n    } catch {\n      setSubmitError(\"Network error. Please try again.\");\n    }\n  };\n\n  return (\n    <form onSubmit={handleSubmit(onSubmit)} noValidate className=\"space-y-4\">\n      <h3 className=\"font-semibold text-gray-900\">Write a review</h3>\n\n      <div>\n        <label htmlFor=\"guestName\" className=\"block text-sm font-medium text-gray-700 mb-1\">\n          Your name <span aria-hidden className=\"text-red-500\">*</span>\n        </label>\n        <input\n          id=\"guestName\"\n          type=\"text\"\n          autoComplete=\"name\"\n          {...register(\"guestName\")}\n          className=\"w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500\"\n          aria-invalid={!!errors.guestName}\n          aria-describedby={errors.guestName ? \"guestName-error\" : undefined}\n        />\n        {errors.guestName && (\n          <p id=\"guestName-error\" role=\"alert\" className=\"text-red-500 text-xs mt-1\">\n            {errors.guestName.message}\n          </p>\n        )}\n      </div>\n\n      <div>\n        <fieldset>\n          <legend className=\"block text-sm font-medium text-gray-700 mb-1\">\n            Rating <span aria-hidden className=\"text-red-500\">*</span>\n          </legend>\n          <div\n            className=\"flex items-center gap-1\"\n            role=\"group\"\n            aria-invalid={!!errors.rating}\n            aria-describedby={errors.rating ? \"rating-error\" : undefined}\n          >\n            {[1, 2, 3, 4, 5].map((val) => (\n              <button\n                key={val}\n                type=\"button\"\n                aria-label={`Rate ${val} star${val !== 1 ? \"s\" : \"\"}`}\n                aria-pressed={rating === val}\n                onClick={() => setValue(\"rating\", val, { shouldValidate: true })}\n                onMouseEnter={() => setHoverRating(val)}\n                onMouseLeave={() => setHoverRating(0)}\n                className=\"focus:outline-none focus:ring-2 focus:ring-blue-500 rounded\"\n              >\n                <Star\n                  size={24}\n                  className={`transition-colors ${\n                    val <= (hoverRating || rating) ? \"text-amber-400 fill-amber-400\" : \"text-gray-200 fill-gray-200\"\n                  }`}\n                  aria-hidden\n                />\n              </button>\n            ))}\n          </div>\n          {errors.rating && (\n            <p id=\"rating-error\" role=\"alert\" className=\"text-red-500 text-xs mt-1\">\n              Please select a rating\n            </p>\n          )}\n        </fieldset>\n      </div>\n\n      <div>\n        <label htmlFor=\"text\" className=\"block text-sm font-medium text-gray-700 mb-1\">\n          Review <span aria-hidden className=\"text-red-500\">*</span>\n        </label>\n        <textarea\n          id=\"text\"\n          rows={4}\n          {...register(\"text\")}\n          placeholder=\"Share your experience...\"\n          className=\"w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none\"\n          aria-invalid={!!errors.text}\n          aria-describedby={errors.text ? \"text-error\" : undefined}\n        />\n        {errors.text && (\n          <p id=\"text-error\" role=\"alert\" className=\"text-red-500 text-xs mt-1\">\n            {errors.text.message}\n          </p>\n        )}\n      </div>\n\n      {submitError && (\n        <p role=\"alert\" className=\"text-red-500 text-sm\">\n          {submitError}\n        </p>\n      )}\n\n      <button\n        type=\"submit\"\n        disabled={isSubmitting}\n        className=\"flex items-center justify-center gap-2 w-full bg-blue-600 hover:bg-blue-700 disabled:bg-blue-400 text-white font-semibold py-2.5 rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2\"\n      >\n        {isSubmitting && <Loader2 size={16} className=\"animate-spin\" aria-hidden />}\n        {isSubmitting ? \"Submitting...\" : \"Submit Review\"}\n      </button>\n    </form>\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":654,"cache_read_input_tokens":68343,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":654},"output_tokens":69,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"1a46cfe3-edd5-47d3-88ea-9b5bc1fd0648","uuid":"e4d668e0-84d7-44bb-8d2c-fcbfeeab9f24","request_id":"req_011CcdSz5mbEy4owLYYmK4f2"}
