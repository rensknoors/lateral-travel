{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014VfnzwB9XC6yZmvAxmPFFb","type":"tool_result","content":"The file /Users/rensknoors/repos/lateral-assessment/components/booking/checkout-form.tsx has been updated successfully. (file state is current in your context — no need to Read it back)"}]},"parent_tool_use_id":null,"session_id":"1a46cfe3-edd5-47d3-88ea-9b5bc1fd0648","uuid":"7c9ec323-0ff3-49ff-93ff-cc1251424521","timestamp":"2026-07-02T15:20:21.148Z","tool_use_result":{"filePath":"/Users/rensknoors/repos/lateral-assessment/components/booking/checkout-form.tsx","oldString":"  const onSubmit = async (data: BookingInput) => {\n    setSubmitError(\"\");\n    try {\n      const res = await fetch(\"/api/bookings\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify(data),\n      });","newString":"  const onSubmit = async (data: BookingInput) => {\n    setSubmitError(\"\");\n    try {\n      const payload = {\n        ...data,\n        hotelId: hotel.id,\n        checkIn,\n        checkOut,\n        guests,\n      };\n      const res = await fetch(\"/api/bookings\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify(payload),\n      });","originalFile":"\"use client\";\n\nimport { useState } from \"react\";\nimport { useRouter } from \"next/navigation\";\nimport { useForm } from \"react-hook-form\";\nimport { zodResolver } from \"@hookform/resolvers/zod\";\nimport { bookingSchema, BookingInput } from \"@/lib/schemas/booking-schema\";\nimport { Hotel } from \"@/lib/types\";\nimport { formatPrice, formatShortDate } from \"@/lib/utils/format\";\nimport { Loader2, Lock, CreditCard } from \"lucide-react\";\n\ninterface CheckoutFormProps {\n  hotel: Hotel;\n  checkIn: string;\n  checkOut: string;\n  guests: number;\n  nights: number;\n  totalPrice: number;\n}\n\nexport function CheckoutForm({ hotel, checkIn, checkOut, guests, nights, totalPrice }: CheckoutFormProps) {\n  const router = useRouter();\n  const [submitError, setSubmitError] = useState(\"\");\n\n  const {\n    register,\n    handleSubmit,\n    formState: { errors, isSubmitting },\n  } = useForm<BookingInput>({\n    resolver: zodResolver(bookingSchema),\n    defaultValues: {\n      hotelId: hotel.id,\n      checkIn,\n      checkOut,\n      guests,\n    },\n  });\n\n  const onSubmit = async (data: BookingInput) => {\n    setSubmitError(\"\");\n    try {\n      const res = await fetch(\"/api/bookings\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify(data),\n      });\n      if (!res.ok) {\n        const err = await res.json();\n        setSubmitError(err.error ?? \"Booking failed. Please try again.\");\n        return;\n      }\n      const booking = await res.json();\n      router.push(`/checkout/confirmation/${booking.id}`);\n    } catch {\n      setSubmitError(\"Network error. Please try again.\");\n    }\n  };\n\n  const inputClass = (hasError: boolean) =>\n    `w-full border ${hasError ? \"border-red-400\" : \"border-gray-300\"} rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500`;\n\n  return (\n    <div className=\"grid lg:grid-cols-[1fr_380px] gap-8 items-start\">\n      <form onSubmit={handleSubmit(onSubmit)} noValidate className=\"space-y-6\">\n        <input type=\"hidden\" {...register(\"hotelId\")} />\n        <input type=\"hidden\" {...register(\"checkIn\")} />\n        <input type=\"hidden\" {...register(\"checkOut\")} />\n        <input type=\"hidden\" {...register(\"guests\", { valueAsNumber: true })} />\n\n        <section>\n          <h2 className=\"text-lg font-semibold text-gray-900 mb-4\">Guest information</h2>\n          <div className=\"space-y-4\">\n            <div>\n              <label htmlFor=\"guestName\" className=\"block text-sm font-medium text-gray-700 mb-1\">\n                Full name <span aria-hidden className=\"text-red-500\">*</span>\n              </label>\n              <input\n                id=\"guestName\"\n                type=\"text\"\n                autoComplete=\"name\"\n                {...register(\"guestName\")}\n                className={inputClass(!!errors.guestName)}\n                aria-invalid={!!errors.guestName}\n                aria-describedby={errors.guestName ? \"name-error\" : undefined}\n              />\n              {errors.guestName && (\n                <p id=\"name-error\" role=\"alert\" className=\"text-red-500 text-xs mt-1\">\n                  {errors.guestName.message}\n                </p>\n              )}\n            </div>\n\n            <div>\n              <label htmlFor=\"guestEmail\" className=\"block text-sm font-medium text-gray-700 mb-1\">\n                Email <span aria-hidden className=\"text-red-500\">*</span>\n              </label>\n              <input\n                id=\"guestEmail\"\n                type=\"email\"\n                autoComplete=\"email\"\n                {...register(\"guestEmail\")}\n                className={inputClass(!!errors.guestEmail)}\n                aria-invalid={!!errors.guestEmail}\n                aria-describedby={errors.guestEmail ? \"email-error\" : undefined}\n              />\n              {errors.guestEmail && (\n                <p id=\"email-error\" role=\"alert\" className=\"text-red-500 text-xs mt-1\">\n                  {errors.guestEmail.message}\n                </p>\n              )}\n            </div>\n          </div>\n        </section>\n\n        <section>\n          <h2 className=\"text-lg font-semibold text-gray-900 mb-1 flex items-center gap-2\">\n            <CreditCard size={20} aria-hidden />\n            Payment\n          </h2>\n          <p className=\"text-sm text-gray-500 mb-4 flex items-center gap-1\">\n            <Lock size={12} aria-hidden />\n            Test mode — no real charge will be made\n          </p>\n          <div className=\"space-y-4\">\n            <div>\n              <label htmlFor=\"cardNumber\" className=\"block text-sm font-medium text-gray-700 mb-1\">\n                Card number <span aria-hidden className=\"text-red-500\">*</span>\n              </label>\n              <input\n                id=\"cardNumber\"\n                type=\"text\"\n                maxLength={16}\n                placeholder=\"1234567890123456\"\n                autoComplete=\"cc-number\"\n                {...register(\"cardNumber\")}\n                className={inputClass(!!errors.cardNumber)}\n                aria-invalid={!!errors.cardNumber}\n                aria-describedby={errors.cardNumber ? \"card-error\" : undefined}\n              />\n              {errors.cardNumber && (\n                <p id=\"card-error\" role=\"alert\" className=\"text-red-500 text-xs mt-1\">\n                  {errors.cardNumber.message}\n                </p>\n              )}\n            </div>\n\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div>\n                <label htmlFor=\"cardExpiry\" className=\"block text-sm font-medium text-gray-700 mb-1\">\n                  Expiry <span aria-hidden className=\"text-red-500\">*</span>\n                </label>\n                <input\n                  id=\"cardExpiry\"\n                  type=\"text\"\n                  maxLength={5}\n                  placeholder=\"MM/YY\"\n                  autoComplete=\"cc-exp\"\n                  {...register(\"cardExpiry\")}\n                  className={inputClass(!!errors.cardExpiry)}\n                  aria-invalid={!!errors.cardExpiry}\n                  aria-describedby={errors.cardExpiry ? \"expiry-error\" : undefined}\n                />\n                {errors.cardExpiry && (\n                  <p id=\"expiry-error\" role=\"alert\" className=\"text-red-500 text-xs mt-1\">\n                    {errors.cardExpiry.message}\n                  </p>\n                )}\n              </div>\n\n              <div>\n                <label htmlFor=\"cardCvc\" className=\"block text-sm font-medium text-gray-700 mb-1\">\n                  CVC <span aria-hidden className=\"text-red-500\">*</span>\n                </label>\n                <input\n                  id=\"cardCvc\"\n                  type=\"text\"\n                  maxLength={4}\n                  placeholder=\"123\"\n                  autoComplete=\"cc-csc\"\n                  {...register(\"cardCvc\")}\n                  className={inputClass(!!errors.cardCvc)}\n                  aria-invalid={!!errors.cardCvc}\n                  aria-describedby={errors.cardCvc ? \"cvc-error\" : undefined}\n                />\n                {errors.cardCvc && (\n                  <p id=\"cvc-error\" role=\"alert\" className=\"text-red-500 text-xs mt-1\">\n                    {errors.cardCvc.message}\n                  </p>\n                )}\n              </div>\n            </div>\n          </div>\n        </section>\n\n        {submitError && (\n          <p role=\"alert\" className=\"text-red-500 text-sm bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n            {submitError}\n          </p>\n        )}\n\n        <button\n          type=\"submit\"\n          disabled={isSubmitting}\n          aria-busy={isSubmitting}\n          className=\"w-full flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 disabled:bg-blue-400 text-white font-semibold py-3.5 rounded-xl text-base transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2\"\n        >\n          {isSubmitting && <Loader2 size={18} className=\"animate-spin\" aria-hidden />}\n          {isSubmitting ? \"Confirming booking...\" : `Confirm booking — ${formatPrice(totalPrice)}`}\n        </button>\n      </form>\n\n      <aside className=\"border border-gray-200 rounded-2xl p-6 space-y-4 sticky top-24\">\n        <div className=\"flex gap-4\">\n          {hotel.photos[0] && (\n            <div\n              className=\"w-20 h-20 rounded-xl overflow-hidden shrink-0 bg-gray-100\"\n              style={{ backgroundImage: `url(${hotel.photos[0]})`, backgroundSize: \"cover\", backgroundPosition: \"center\" }}\n              role=\"img\"\n              aria-label={hotel.name}\n            />\n          )}\n          <div>\n            <div className=\"text-xs text-gray-400 mb-1\">{\"★\".repeat(hotel.starRating)}</div>\n            <h3 className=\"font-semibold text-gray-900 text-sm leading-snug\">{hotel.name}</h3>\n            <p className=\"text-xs text-gray-500 mt-0.5\">{hotel.destination}</p>\n          </div>\n        </div>\n\n        <div className=\"border-t border-gray-100 pt-4 space-y-2 text-sm\">\n          <div className=\"flex justify-between text-gray-600\">\n            <span>Check-in</span>\n            <span className=\"font-medium\">{formatShortDate(checkIn)}</span>\n          </div>\n          <div className=\"flex justify-between text-gray-600\">\n            <span>Check-out</span>\n            <span className=\"font-medium\">{formatShortDate(checkOut)}</span>\n          </div>\n          <div className=\"flex justify-between text-gray-600\">\n            <span>Guests</span>\n            <span className=\"font-medium\">{guests}</span>\n          </div>\n        </div>\n\n        <div className=\"border-t border-gray-100 pt-4 space-y-2 text-sm\">\n          <div className=\"flex justify-between text-gray-600\">\n            <span>{formatPrice(hotel.pricePerNight)} × {nights} night{nights !== 1 ? \"s\" : \"\"}</span>\n            <span>{formatPrice(hotel.pricePerNight * nights)}</span>\n          </div>\n          <div className=\"flex justify-between font-semibold text-gray-900 text-base border-t border-gray-100 pt-2\">\n            <span>Total</span>\n            <span>{formatPrice(totalPrice)}</span>\n          </div>\n        </div>\n      </aside>\n    </div>\n  );\n}\n","structuredPatch":[{"oldStart":39,"oldLines":10,"newStart":39,"newLines":17,"lines":["   const onSubmit = async (data: BookingInput) => {","     setSubmitError(\"\");","     try {","+      const payload = {","+        ...data,","+        hotelId: hotel.id,","+        checkIn,","+        checkOut,","+        guests,","+      };","       const res = await fetch(\"/api/bookings\", {","         method: \"POST\",","         headers: { \"Content-Type\": \"application/json\" },","-        body: JSON.stringify(data),","+        body: JSON.stringify(payload),","       });","       if (!res.ok) {","         const err = await res.json();"]}],"userModified":false,"replaceAll":false}}
