{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01SavbhL3gwdprqJm7BP21KT","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01QfJeU8u4KiPggKRZCjEnxg","name":"Write","input":{"file_path":"/Users/rensknoors/repos/lateral-assessment/components/hotels/hotel-card.tsx","content":"import Link from \"next/link\";\nimport Image from \"next/image\";\nimport { MapPin, Star, Users } from \"lucide-react\";\nimport { Hotel } from \"@/lib/types\";\nimport { formatPrice } from \"@/lib/utils/format\";\nimport { FavoriteButton } from \"@/components/favorites/favorite-button\";\n\ninterface HotelCardProps {\n  hotel: Hotel;\n  checkIn?: string;\n  checkOut?: string;\n  guests?: number;\n}\n\nexport function HotelCard({ hotel, checkIn, checkOut, guests }: HotelCardProps) {\n  const searchParams = new URLSearchParams();\n  if (checkIn) searchParams.set(\"checkIn\", checkIn);\n  if (checkOut) searchParams.set(\"checkOut\", checkOut);\n  if (guests) searchParams.set(\"guests\", String(guests));\n  const qs = searchParams.toString() ? `?${searchParams.toString()}` : \"\";\n\n  return (\n    <Link\n      href={`/hotels/${hotel.id}${qs}`}\n      className=\"group block bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-md transition-shadow focus:outline-none focus:ring-2 focus:ring-blue-500\"\n    >\n      <div className=\"relative h-48 overflow-hidden\">\n        <Image\n          src={hotel.photos[0]}\n          alt={hotel.name}\n          fill\n          className=\"object-cover group-hover:scale-105 transition-transform duration-300\"\n          sizes=\"(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw\"\n        />\n        <div className=\"absolute top-3 right-3\">\n          <FavoriteButton hotelId={hotel.id} />\n        </div>\n        <div className=\"absolute top-3 left-3 bg-white/90 backdrop-blur-sm rounded-full px-2 py-0.5 text-xs font-medium text-gray-700\">\n          {\"★\".repeat(hotel.starRating)}\n        </div>\n      </div>\n      <div className=\"p-4\">\n        <h3 className=\"font-semibold text-gray-900 text-base leading-tight mb-1 group-hover:text-blue-600 transition-colors\">\n          {hotel.name}\n        </h3>\n        <div className=\"flex items-center gap-1 text-gray-500 text-sm mb-2\">\n          <MapPin size={13} aria-hidden />\n          <span>{hotel.destination}</span>\n        </div>\n        {hotel.averageRating > 0 ? (\n          <div className=\"flex items-center gap-1.5 mb-3\">\n            <div className=\"flex items-center gap-0.5 text-amber-400\">\n              <Star size={14} fill=\"currentColor\" aria-hidden />\n              <span className=\"text-sm font-medium text-gray-700\">{hotel.averageRating.toFixed(1)}</span>\n            </div>\n            <span className=\"text-sm text-gray-400\">({hotel.reviewCount} reviews)</span>\n          </div>\n        ) : (\n          <div className=\"mb-3 text-sm text-gray-400\">No reviews yet</div>\n        )}\n        <div className=\"flex items-center justify-between\">\n          <div>\n            <span className=\"text-lg font-bold text-gray-900\">{formatPrice(hotel.pricePerNight)}</span>\n            <span className=\"text-sm text-gray-400\"> / night</span>\n          </div>\n          <div className=\"flex items-center gap-1 text-gray-400 text-sm\">\n            <Users size={13} aria-hidden />\n            <span>Up to {hotel.maxGuests}</span>\n          </div>\n        </div>\n      </div>\n    </Link>\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":478,"cache_read_input_tokens":61309,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":478},"output_tokens":67,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"1a46cfe3-edd5-47d3-88ea-9b5bc1fd0648","uuid