{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01Sp8Q6ptCrk4YVHgBFw3WM6","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01XXcZVFnZzf1Vu5QxFYsQ7K","name":"Write","input":{"file_path":"/Users/rensknoors/repos/lateral-assessment/app/api/hotels/[id]/reviews/route.ts","content":"import type { NextRequest } from \"next/server\";\nimport { getReviewsByHotelId, addReview, getHotelById } from \"@/lib/hotels\";\nimport { reviewSchema } from \"@/lib/schemas/review-schema\";\n\nexport async function GET(\n  _request: NextRequest,\n  { params }: { params: Promise<{ id: string }> }\n) {\n  try {\n    const { id } = await params;\n    if (!getHotelById(id)) {\n      return Response.json({ error: \"Hotel not found\" }, { status: 404 });\n    }\n    const result = getReviewsByHotelId(id);\n    return Response.json(result);\n  } catch {\n    return Response.json({ error: \"Internal server error\" }, { status: 500 });\n  }\n}\n\nexport async function POST(\n  request: NextRequest,\n  { params }: { params: Promise<{ id: string }> }\n) {\n  try {\n    const { id } = await params;\n    if (!getHotelById(id)) {\n      return Response.json({ error: \"Hotel not found\" }, { status: 404 });\n    }\n\n    const body = await request.json();\n    const parsed = reviewSchema.safeParse(body);\n    if (!parsed.success) {\n      return Response.json({ error: \"Invalid review data\", details: parsed.error.flatten() }, { status: 400 });\n    }\n\n    const review = addReview(id, parsed.data);\n    return Response.json(review, { status: 201 });\n  } catch {\n    return Response.json({ error: \"Internal server error\" }, { status: 500 });\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":415,"cache_read_input_tokens":54287,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":415},"output_tokens":70,"service_tier":"standard