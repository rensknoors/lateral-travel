nst validBooking = {\n    hotelId: \"h1\",\n    checkIn: \"2026-08-01\",\n    checkOut: \"2026-08-05\",\n    guests: 2,\n    guestName: \"Bob Smith\",\n    guestEmail: \"bob@example.com\",\n    cardNumber: \"1234567890123456\",\n    cardExpiry: \"12/27\",\n    cardCvc: \"123\",\n  };\n\n  it(\"accepts a valid booking\", () => {\n    expect(bookingSchema.safeParse(validBooking).success).toBe(true);\n  });\n\n  it(\"rejects invalid email\", () => {\n    expect(bookingSchema.safeParse({ ...validBooking, guestEmail: \"not-an-email\" }).success).toBe(false);\n  });\n\n  it(\"rejects card number not 16 digits\", () => {\n    expect(bookingSchema.safeParse({ ...validBooking, cardNumber: \"123\" }).success).toBe(false);\n  });\n\n  it(\"rejects invalid expiry format\", () => {\n    expect(bookingSchema.safeParse({ ...validBooking, cardExpiry: \"1227\" }).success).toBe(false);\n  });\n\n  it(\"rejects checkout before checkin\", () => {\n    expect(\n      bookingSchema.safeParse({ ...validBooking, checkIn: \"2026-08-05\", checkOut: \"2026-08-01\" }).success\n    ).toBe(false);\n  });\n\n  it(\"rejects zero guests\", () => {\n    expect(bookingSchema.safeParse({ ...validBooking, guests: 0 }).success).toBe(false);\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
