{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01AkgieXnb9EvUgViPBLVzrM","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_012bi9xufF5YhMcWqMdJzbHm","name":"Write","input":{"file_path":"/Users/rensknoors/repos/lateral-assessment/tests/filter-hotels.spec.ts","content":"import { describe, it, expect } from \"vitest\";\nimport { getHotels } from \"@/lib/hotels\";\n\ndescribe(\"getHotels\", () => {\n  it(\"returns all hotels when no filters are applied\", () => {\n    const { data, total } = getHotels({});\n    expect(total).toBeGreaterThan(0);\n    expect(data.length).toBe(total);\n  });\n\n  it(\"filters by destination case-insensitively\", () => {\n    const { data } = getHotels({ destination: \"paris\" });\n    expect(data.length).toBeGreaterThan(0);\n    data.forEach((h) => expect(h.destination.toLowerCase()).toContain(\"paris\"));\n  });\n\n  it(\"returns empty array for destination with no matches\", () => {\n    const { data, total } = getHotels({ destination: \"NonexistentCity12345\" });\n    expect(data.length).toBe(0);\n    expect(total).toBe(0);\n  });\n\n  it(\"filters by minimum guests\", () => {\n    const { data } = getHotels({ guests: 4 });\n    data.forEach((h) => expect(h.maxGuests).toBeGreaterThanOrEqual(4));\n  });\n\n  it(\"filters by minPrice\", () => {\n    const { data } = getHotels({ minPrice: 30000 });\n    data.forEach((h) => expect(h.pricePerNight).toBeGreaterThanOrEqual(30000));\n  });\n\n  it(\"filters by maxPrice\", () => {\n    const { data } = getHotels({ maxPrice: 20000 });\n    data.forEach((h) => expect(h.pricePerNight).toBeLessThanOrEqual(20000));\n  });\n\n  it(\"filters by minRating\", () => {\n    const { data } = getHotels({ minRating: 4.5 });\n    data.forEach((h) => expect(h.averageRating).toBeGreaterThanOrEqual(4.5));\n  });\n\n  it(\"filters by a single amenity\", () => {\n    const { data } = getHotels({ amenities: [\"pool\"] });\n    data.forEach((h) => expect(h.amenities).toContain(\"pool\"));\n  });\n\n  it(\"filters by multiple amenities (must have all)\", () => {\n    const { data } = getHotels({ amenities: [\"wifi\", \"spa\"] });\n    data.forEach((h) => {\n      expect(h.amenities).toContain(\"wifi\");\n      expect(h.amenities).toContain(\"spa\");\n    });\n  });\n\n  it(\"sorts by price ascending\", () => {\n    const { data } = getHotels({ sort: \"price_asc\" });\n    for (let i = 1; i < data.length; i++) {\n      expect(data[i].pricePerNight).toBeGreaterThanOrEqual(data[i - 1].pricePerNight);\n    }\n  });\n\n  it(\"sorts by price descending\", () => {\n    const { data } = getHotels({ sort: \"price_desc\" });\n    for (let i = 1; i < data.length; i++) {\n      expect(data[i].pricePerNight).toBeLessThanOrEqual(data[i - 1].pricePerNight);\n    }\n  });\n\n  it(\"sorts by rating descending\", () => {\n    const { data } = getHotels({ sort: \"rating_desc\" });\n    for (let i = 1; i < data.length; i++) {\n      expect(data[i].averageRating).toBeLessThanOrEqual(data[i - 1].averageRating);\n    }\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":248,"cache_read_input_tokens":87729,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":248},"output_tokens":59,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"1a46cfe3-edd5-47d3-88ea-9b5bc1fd0648","uuid":"c3779a93-35a0-44ac-ab3e-88aef3a1ca53","request_id":"req_011CcdTGw4S7yv6LRGP4nyeZ"}
