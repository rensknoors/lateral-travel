ack to hotel\n        </Link>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8\">\n      <Link\n        href={`/hotels/${hotelId}`}\n        className=\"inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-900 mb-6 focus:outline-none focus:ring-2 focus:ring-blue-500 rounded\"\n      >\n        <ArrowLeft size={16} aria-hidden=\"true\" />\n        Back to hotel\n      </Link>\n\n      <h1 className=\"text-2xl font-bold text-gray-900 mb-8\">Complete your booking</h1>\n\n      <CheckoutForm\n        hotel={hotel}\n        checkIn={resolvedCheckIn}\n        checkOut={resolvedCheckOut}\n        guests={guests}\n        nights={availability.nights}\n        totalPrice={availability.totalPrice}\n      />\n    </div>\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":808,"cache_read_input_tokens":81707,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":808},"output_tokens":58,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"1a46cfe3-edd5-47d3-88ea-9b5bc1fd0648","uuid":"8aaf59bf-9092-475a-bc49-7fe979dec7a0","request_id":"req_011CcdTB2yDeuzVQS1ZvAh6T"}
