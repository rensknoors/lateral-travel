{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01MSFf4ndR4VaPySsyLUkDc9","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Pn3JBG8z6a2AE8kvW9WKR4","name":"Write","input":{"file_path":"/Users/rensknoors/repos/lateral-assessment/lib/hotels.ts","content":"import hotelsData from \"@/data/hotels.json\";\nimport reviewsData from \"@/data/reviews.json\";\nimport { Hotel, Review, SearchQuery } from \"./types\";\n\nconst hotels: Hotel[] = hotelsData as Hotel[];\nconst reviews: Review[] = reviewsData as Review[];\n\nexport function getHotels(query: SearchQuery = {}): { data: Hotel[]; total: number } {\n  let result = [...hotels];\n\n  if (query.destination && query.destination.trim()) {\n    const dest = query.destination.toLowerCase().trim();\n    result = result.filter((h) => h.destination.toLowerCase().includes(dest));\n  }\n\n  if (query.guests) {\n    result = result.filter((h) => h.maxGuests >= query.guests!);\n  }\n\n  if (query.minPrice !== undefined) {\n    result = result.filter((h) => h.pricePerNight >= query.minPrice!);\n  }\n\n  if (query.maxPrice !== undefined) {\n    result = result.filter((h) => h.pricePerNight <= query.maxPrice!);\n  }\n\n  if (query.minRating !== undefined) {\n    result = result.filter((h) => h.averageRating >= query.minRating!);\n  }\n\n  if (query.amenities && query.amenities.length > 0) {\n    result = result.filter((h) =>\n      query.amenities!.every((a) => h.amenities.includes(a))\n    );\n  }\n\n  if (query.sort === \"price_asc\") {\n    result.sort((a, b) => a.pricePerNight - b.pricePerNight);\n  } else if (query.sort === \"price_desc\") {\n    result.sort((a, b) => b.pricePerNight - a.pricePerNight);\n  } else if (query.sort === \"rating_desc\") {\n    result.sort((a, b) => b.averageRating - a.averageRating);\n  }\n\n  return { data: result, total: result.length };\n}\n\nexport function getHotelById(id: string): Hotel | undefined {\n  return hotels.find((h) => h.id === id);\n}\n\nexport function getReviewsByHotelId(hotelId: string): { data: Review[]; total: number } {\n  const data = reviews\n    .filter((r) => r.hotelId === hotelId)\n    .sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime());\n  return { data, total: data.length };\n}\n\nexport function addReview(hotelId: string, input: { guestName: string; rating: number; text: string }): Review {\n  const review: Review = {\n    id: `r${Date.now()}`,\n    hotelId,\n    guestName: input.guestName,\n    rating: input.rating,\n    text: input.text,\n    createdAt: new Date().toISOString(),\n  };\n  reviews.push(review);\n\n  const hotel = hotels.find((h) => h.id === hotelId);\n  if (hotel) {\n    const hotelReviews = reviews.filter((r) => r.hotelId === hotelId);\n    hotel.reviewCount = hotelReviews.length;\n    hotel.averageRating = Math.round(\n      (hotelReviews.reduce((sum, r) => sum + r.rating, 0) / hotelReviews.length) * 10\n    ) / 10;\n  }\n\n  return review;\n}\n\nexport function computeAvailability(\n  hotelId: string,\n  checkIn: string,\n  checkOut: string,\n  guests: number\n): { available: boolean; nights: number; pricePerNight: number; totalPrice: number } | null {\n  const hotel = hotels.find((h) => h.id === hotelId);\n  if (!hotel) return null;\n\n  const checkInDate = new Date(checkIn);\n  const checkOutDate = new Date(checkOut);\n  const nights = Math.round((checkOutDate.getTime() - checkInDate.getTime()) / (1000 * 60 * 60 * 24));\n\n  const available = nights > 0 && guests >= 1 && guests <= hotel.maxGuests;\n\n  return {\n    available,\n    nights,\n    pricePerNight: hotel.pricePerNight,\n    totalPrice: available ? hotel.pricePerNight * nights : 0,\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":390,"cache_read_input_tokens":51352,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":390},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"1a46cfe3-edd5-47d3-88ea-9b5bc1fd0648","uuid":"33176db8-fae4-4316-8c05-650d441339ac","request_id":"req_011CcdSgcfwwzeC65epz7tgK"}
