{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01NMjcVM2nnqjsiMX6fFYfyK","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01U6avVDTeVSKq8CeXnPmTQA","name":"Write","input":{"file_path":"/Users/rensknoors/repos/lateral-assessment/tests/pricing.spec.ts","content":"import { describe, it, expect } from \"vitest\";\nimport { computeAvailability } from \"@/lib/hotels\";\n\nconst HOTEL_ID = \"h1\";\n\ndescribe(\"computeAvailability\", () => {\n  it(\"returns null for an unknown hotel\", () => {\n    const result = computeAvailability(\"unknown-id\", \"2026-08-01\", \"2026-08-05\", 2);\n    expect(result).toBeNull();\n  });\n\n  it(\"calculates correct night count\", () => {\n    const result = computeAvailability(HOTEL_ID, \"2026-08-01\", \"2026-08-05\", 2);\n    expect(result?.nights).toBe(4);\n  });\n\n  it(\"marks unavailable when checkout is before checkin\", () => {\n    const result = computeAvailability(HOTEL_ID, \"2026-08-05\", \"2026-08-01\", 2);\n    expect(result?.available).toBe(false);\n  });\n\n  it(\"marks unavailable when checkout equals checkin\", () => {\n    const result = computeAvailability(HOTEL_ID, \"2026-08-01\", \"2026-08-01\", 2);\n    expect(result?.available).toBe(false);\n  });\n\n  it(\"marks unavailable when guests exceed maxGuests\", () => {\n    const result = computeAvailability(HOTEL_ID, \"2026-08-01\", \"2026-08-05\", 999);\n    expect(result?.available).toBe(false);\n  });\n\n  it(\"computes correct total price\", () => {\n    const result = computeAvailability(HOTEL_ID, \"2026-08-01\", \"2026-08-05\", 2);\n    expect(result?.totalPrice).toBe(result!.pricePerNight * result!.nights);\n  });\n\n  it(\"marks available for valid dates and guest count\", () => {\n    const result = computeAvailability(HOTEL_ID, \"2026-08-01\", \"2026-08-05\", 2);\n    expect(result?.available).toBe(true);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,