{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_018DgWSZkYwdxWWP4ciWoFUx","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_017qQm1MBKz97TNH4xTS7cuj","name":"Write","input":{"file_path":"/Users/rensknoors/repos/lateral-assessment/components/booking/date-guest-picker.tsx","content":"\"use client\";\n\nimport { useState, useEffect } from \"react\";\nimport { useRouter, useSearchParams } from \"next/navigation\";\nimport { Calendar, Users, Loader2 } from \"lucide-react\";\nimport { formatPrice } from \"@/lib/utils/format\";\nimport { AvailabilityResult, Hotel } from \"@/lib/types\";\n\ninterface DateGuestPickerProps {\n  hotel: Hotel;\n}\n\nexport function DateGuestPicker({ hotel }: DateGuestPickerProps) {\n  const router = useRouter();\n  const searchParams = useSearchParams();\n\n  const today = new Date().toISOString().split(\"T\")[0];\n  const tomorrow = new Date(Date.now() + 86400000).toISOString().split(\"T\")[0];\n\n  const [checkIn, setCheckIn] = useState(searchParams.get(\"checkIn\") ?? today);\n  const [checkOut, setCheckOut] = useState(searchParams.get(\"checkOut\") ?? tomorrow);\n  const [guests, setGuests] = useState(Number(searchParams.get(\"guests\") ?? 2));\n  const [availability, setAvailability] = useState<AvailabilityResult | null>(null);\n  const [loading, setLoading] = useState(false);\n  const [error, setError] = useState(\"\");\n\n  useEffect(() => {\n    if (!checkIn || !checkOut) return;\n    if (new Date(checkOut) <= new Date(checkIn)) {\n      setError(\"Check-out must be after check-in\");\n      setAvailability(null);\n      return;\n    }\n    if (guests < 1 || guests > hotel.maxGuests) {\n      setError(`This hotel allows 1–${hotel.maxGuests} guests`);\n      setAvailability(null);\n      return;\n    }\n    setError(\"\");\n\n    const controller = new AbortController();\n    setLoading(true);\n\n    fetch(\n      `/api/hotels/${hotel.id}/availability?checkIn=${checkIn}&checkOut=${checkOut}&guests=${guests}`,\n      { signal: controller.signal }\n    )\n      .then((res) => res.json())\n      .then((data: AvailabilityResult) => {\n        setAvailability(data);\n        setLoading(false);\n      })\n      .catch((err) => {\n        if (err.name !== \"AbortError\") setLoading(false);\n      });\n\n    return () => controller.abort();\n  }, [checkIn, checkOut, guests, hotel.id, hotel.maxGuests]);\n\n  const handleReserve = () => {\n    const params = new URLSearchParams({ checkIn, checkOut, guests: String(guests) });\n    router.push(`/checkout/${hotel.id}?${params.toString()}`);\n  };\n\n  return (\n    <div className=\"border border-gray-200 rounded-2xl p-6 shadow-lg space-y-4 sticky top-24\">\n      <div className=\"flex items-baseline gap-1\">\n        <span className=\"text-2xl font-bold text-gray-900\">{formatPrice(hotel.pricePerNight)}</span>\n        <span className=\"text-gray-500\">/ night</span>\n      </div>\n\n      <div className=\"grid grid-cols-2 gap-2\">\n        <div className=\"border border-gray-300 rounded-lg p-3\">\n          <label htmlFor=\"picker-checkin\" className=\"flex items-center gap-1 text-xs font-semibold text-gray-700 mb-1\">\n            <Calendar size={12} aria-hidden />\n            CHECK-IN\n          </label>\n          <input\n            id=\"picker-checkin\"\n            type=\"date\"\n            value={checkIn}\n            min={today}\n            onChange={(e) => setCheckIn(e.target.value)}\n            className=\"w-full text-sm text-gray-900 outline-none\"\n          />\n        </div>\n        <div className=\"border border-gray-300 rounded-lg p-3\">\n          <label htmlFor=\"picker-checkout\" className=\"flex items-center gap-1 text-xs font-semibold text-gray-700 mb-1\">\n            <Calendar size={12} aria-hidden />\n            CHECK-OUT\n          </label>\n          <input\n            id=\"picker-checkout\"\n            type=\"date\"\n            value={checkOut}\n            min={checkIn || today}\n            onChange={(e) => setCheckOut(e.target.value)}\n            className=\"w-full text-sm text-gray-900 outline-none\"\n          />\n        </div>\n      </div>\n\n      <div className=\"border border-gray-300 rounded-lg p-3\">\n        <label htmlFor=\"picker-guests\" className=\"flex items-center gap-1 text-xs font-semibold text-gray-700 mb-1\">\n          <Users size={12} aria-hidden />\n          GUESTS\n        </label>\n        <input\n          id=\"picker-guests\"\n          type=\"number\"\n          min={1}\n          max={hotel.maxGuests}\n          value={guests}\n          onChange={(e) => setGuests(Number(e.target.value))}\n          className=\"w-full text-sm text-gray-900 outline-none\"\n        />\n        <p className=\"text-xs text-gray-400 mt-0.5\">Max {hotel.maxGuests} guests</p>\n      </div>\n\n      {error && (\n        <p role=\"alert\" className=\"text-red-500 text-sm\">\n          {error}\n        </p>\n      )}\n\n      {loading && (\n        <div className=\"flex items-center gap-2 text-gray-500 text-sm\" aria-live=\"polite\" aria-label=\"Calculating price\">\n          <Loader2 size={14} className=\"animate-spin\" aria-hidden />\n          Checking availability...\n        </div>\n      )}\n\n      {availability && !loading && !error && (\n        <div className=\"space-y-2 border-t border-gray-100 pt-4\" aria-live=\"polite\">\n          <div className=\"flex justify-between text-sm text-gray-600\">\n            <span>{formatPrice(availability.pricePerNight)} × {availability.nights} night{availability.nights !== 1 ? \"s\" : \"\"}</span>\n            <span>{formatPrice(availability.pricePerNight * availability.nights)}</span>\n          </div>\n          <div className=\"flex justify-between font-semibold text-gray-900 text-base border-t border-gray-100 pt-2\">\n            <span>Total</span>\n            <span>{formatPrice(availability.totalPrice)}</span>\n          </div>\n        </div>\n      )}\n\n      <button\n        onClick={handleReserve}\n        disabled={!!error || loading || !availability?.available}\n        className=\"w-full bg-blue-600 hover:bg-blue-700 disabled:bg-gray-300 disabled:cursor-not-allowed text-white font-semibold py-3 rounded-xl transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2\"\n      >\n        {availability?.available === false ? \"Not Available\" : \"Reserve\"}\n      </button>\n\n      <p className=\"text-center text-xs text-gray-400\">You won&apos;t be charged yet</p>\n    </div>\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1765,"cache_read_input_tokens":68997,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1765},"output_tokens":49,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"1a46cfe3-edd5-47d3-88ea-9b5bc1fd0648","uuid":"ea4ddc8a-552f-480d-a426-5d16ec99a003","request_id":"req_011CcdT1ENnktxcsjZtFwvC8"}
