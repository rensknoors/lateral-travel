{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01Y6DzT3S8RrjHGH6ADRQ5aC","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_015PgXqkP8MZSWWftFa7MLvL","name":"Write","input":{"file_path":"/Users/rensknoors/repos/lateral-assessment/components/search/filter-panel.tsx","content":"\"use client\";\n\nimport { useRouter, useSearchParams } from \"next/navigation\";\nimport { useCallback } from \"react\";\nimport { X } from \"lucide-react\";\n\nconst AMENITY_OPTIONS = [\n  { value: \"wifi\", label: \"WiFi\" },\n  { value: \"pool\", label: \"Pool\" },\n  { value: \"spa\", label: \"Spa\" },\n  { value: \"gym\", label: \"Gym\" },\n  { value: \"restaurant\", label: \"Restaurant\" },\n  { value: \"bar\", label: \"Bar\" },\n  { value: \"parking\", label: \"Parking\" },\n  { value: \"breakfast\", label: \"Breakfast\" },\n  { value: \"beach-access\", label: \"Beach Access\" },\n  { value: \"room-service\", label: \"Room Service\" },\n];\n\nexport function FilterPanel() {\n  const router = useRouter();\n  const searchParams = useSearchParams();\n\n  const minPrice = searchParams.get(\"minPrice\") ?? \"\";\n  const maxPrice = searchParams.get(\"maxPrice\") ?? \"\";\n  const minRating = searchParams.get(\"minRating\") ?? \"\";\n  const selectedAmenities = (searchParams.get(\"amenities\") ?? \"\").split(\",\").filter(Boolean);\n  const sort = searchParams.get(\"sort\") ?? \"\";\n\n  const updateParam = useCallback(\n    (key: string, value: string) => {\n      const params = new URLSearchParams(searchParams.toString());\n      if (value) {\n        params.set(key, value);\n      } else {\n        params.delete(key);\n      }\n      router.push(`/?${params.toString()}`);\n    },\n    [router, searchParams]\n  );\n\n  const toggleAmenity = useCallback(\n    (amenity: string) => {\n      const current = (searchParams.get(\"amenities\") ?? \"\").split(\",\").filter(Boolean);\n      const updated = current.includes(amenity)\n        ? current.filter((a) => a !== amenity)\n        : [...current, amenity];\n      updateParam(\"amenities\", updated.join(\",\"));\n    },\n    [searchParams, updateParam]\n  );\n\n  const resetFilters = () => {\n    const params = new URLSearchParams(searchParams.toString());\n    [\"minPrice\", \"maxPrice\", \"minRating\", \"amenities\", \"sort\"].forEach((k) => params.delete(k));\n    router.push(`/?${params.toString()}`);\n  };\n\n  const hasFilters = minPrice || maxPrice || minRating || selectedAmenities.length > 0 || sort;\n\n  return (\n    <aside className=\"space-y-6\" aria-label=\"Search filters\">\n      <div className=\"flex items-center justify-between\">\n        <h2 className=\"font-semibold text-gray-900\">Filters</h2>\n        {hasFilters && (\n          <button\n            onClick={resetFilters}\n            className=\"flex items-center gap-1 text-sm text-blue-600 hover:text-blue-800 focus:outline-none focus:underline\"\n          >\n            <X size={14} aria-hidden />\n            Reset\n          </button>\n        )}\n      </div>\n\n      <div>\n        <h3 className=\"text-sm font-medium text-gray-700 mb-3\">Sort by</h3>\n        <select\n          value={sort}\n          onChange={(e) => updateParam(\"sort\", e.target.value)}\n          className=\"w-full border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500\"\n          aria-label=\"Sort results\"\n        >\n          <option value=\"\">Recommended</option>\n          <option value=\"price_asc\">Price: Low to High</option>\n          <option value=\"price_desc\">Price: High to Low</option>\n          <option value=\"rating_desc\">Highest Rated</option>\n        </select>\n      </div>\n\n      <div>\n        <h3 className=\"text-sm font-medium text-gray-700 mb-3\">Price per night</h3>\n        <div className=\"flex items-center gap-2\">\n          <div className=\"flex-1\">\n            <label htmlFor=\"min-price\" className=\"sr-only\">Minimum price</label>\n            <input\n              id=\"min-price\"\n              type=\"number\"\n              placeholder=\"Min $\"\n              value={minPrice}\n              onChange={(e) => updateParam(\"minPrice\", e.target.value ? String(Math.round(Number(e.target.value) * 100)) : \"\")}\n              min={0}\n              className=\"w-full border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500\"\n            />\n          </div>\n          <span className=\"text-gray-400\">—</span>\n          <div className=\"flex-1\">\n            <label htmlFor=\"max-price\" className=\"sr-only\">Maximum price</label>\n            <input\n              id=\"max-price\"\n              type=\"number\"\n              placeholder=\"Max $\"\n              value={maxPrice}\n              onChange={(e) => updateParam(\"maxPrice\", e.target.value ? String(Math.round(Number(e.target.value) * 100)) : \"\")}\n              min={0}\n              className=\"w-full border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500\"\n            />\n          </div>\n        </div>\n      </div>\n\n      <div>\n        <h3 className=\"text-sm font-medium text-gray-700 mb-3\">Minimum rating</h3>\n        <select\n          value={minRating}\n          onChange={(e) => updateParam(\"minRating\", e.target.value)}\n          className=\"w-full border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500\"\n          aria-label=\"Minimum star rating\"\n        >\n          <option value=\"\">Any rating</option>\n          <option value=\"4\">4+ stars</option>\n          <option value=\"4.5\">4.5+ stars</option>\n          <option value=\"5\">5 stars only</option>\n        </select>\n      </div>\n\n      <fieldset>\n        <legend className=\"text-sm font-medium text-gray-700 mb-3\">Amenities</legend>\n        <div className=\"space-y-2\">\n          {AMENITY_OPTIONS.map(({ value, label }) => (\n            <label key={value} className=\"flex items-center gap-2 cursor-pointer\">\n              <input\n                type=\"checkbox\"\n                checked={selectedAmenities.includes(value)}\n                onChange={() => toggleAmenity(value)}\n                className=\"w-4 h-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500\"\n              />\n              <span className=\"text-sm text-gray-700\">{label}</span>\n            </label>\n          ))}\n        </div>\n      </fieldset>\n    </aside>\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1624,"cache_read_input_tokens":62909,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1624},"output_tokens":59,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"1a46cfe3-edd5-47d3-88ea-9b5bc1fd0648","uuid":"ac24bc1b-82ce-4745-98c9-2d4f81c48989","request_id":"req_011CcdSvSE3L9astTAvwPrmj"}
