{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_016Rn7TuKQ1H8RRqvK38ypwP","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01C3gUXHK2PsHdK5AdJMBiPx","name":"Write","input":{"file_path":"/Users/rensknoors/repos/lateral-assessment/tests/schemas.spec.ts","content":"import { describe, it, expect } from \"vitest\";\nimport { reviewSchema } from \"@/lib/schemas/review-schema\";\nimport { bookingSchema } from \"@/lib/schemas/booking-schema\";\n\ndescribe(\"reviewSchema\", () => {\n  const validReview = { guestName: \"Alice\", rating: 5, text: \"Great hotel, loved every moment!\" };\n\n  it(\"accepts a valid review\", () => {\n    expect(reviewSchema.safeParse(validReview).success).toBe(true);\n  });\n\n  it(\"rejects short name\", () => {\n    expect(reviewSchema.safeParse({ ...validReview, guestName: \"A\" }).success).toBe(false);\n  });\n\n  it(\"rejects rating below 1\", () => {\n    expect(reviewSchema.safeParse({ ...validReview, rating: 0 }).success).toBe(false);\n  });\n\n  it(\"rejects rating above 5\", () => {\n    expect(reviewSchema.safeParse({ ...validReview, rating: 6 }).success).toBe(false);\n  });\n\n  it(\"rejects text under 10 characters\", () => {\n    expect(reviewSchema.safeParse({ ...validReview, text: \"Short\" }).success).toBe(false);\n  });\n\n  it(\"rejects text over 1000 characters\", () => {\n    expect(reviewSchema.safeParse({ ...validReview, text: \"a\".repeat(1001) }).success).toBe(false);\n  });\n\n  it(\"rejects text with blocked words\", () => {\n    expect(reviewSchema.safeParse({ ...validReview, text: \"This is spam content that is long enough\" }).success).toBe(false);\n  });\n});\n\ndescribe(\"bookingSchema\", () => {\n  const validBooking = {\n    hotelId: \"h1\",\n    checkIn: \"2026-08-01\",\n    checkOut: \"2026-08-05\",\n    guests: 2,\n    guestName: \"Bob Smith\",\n    guestEmail: \"bob@example.com\",\n    cardNumber: \"1234567890123456\",\n    cardExpiry: \"12/27\",\n    cardCvc: \"123\",\n  };\n\n  it(\"accepts a valid booking\", () => {\n    expect(bookingSchema.safeParse(validBooking).success).toBe(true);\n  });\n\n  it(\"rejects invalid email\", () => {\n    expect(bookingSchema.safeParse({ ...validBooking, guestEmail: \"not-an-email\" }).success).toBe(false);\n  });\n\n  it(\"rejects card number not 16 digits\", () => {\n    expect(bookingSchema.safeParse({ ...validBooking, cardNumber: \"123\" }).success).toBe(false);\n  });\n\n  it(\"rejects invalid expiry format\", () => {\n    expect(bookingSchema.safeParse({ ...validBooking, cardExpiry: \"1227\" }).success).toBe(false);\n  });\n\n  it(\"rejects checkout before checkin\", () => {\n    expect(\n      bookingSchema.safeParse({ ...validBooking, checkIn: \"2026-08-05\", checkOut: \"2026-08-01\" }).success\n    ).toBe(false);\n  });\n\n  it(\"rejects zero guests\", () => {\n    expect(bookingSchema.safeParse({ ...validBooking, guests: 0 }).success).toBe(false);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":669,"cache_read_input_tokens":89056,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":669},"output_tokens":71,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"1a46cfe3-edd5-47d3-88ea-9b5bc1fd0648","uuid":"1ec7163a-0b44-418b-b4ed-73d571cc5a32","request_id":"req_011CcdTJr3NEeHsjWUnw8TcT"}
