{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01E3DVNUpCx2zn9oZZdcXgdR","type":"tool_result","content":"1\t\"use client\";\n2\t\n3\timport { useState } from \"react\";\n4\timport { useRouter } from \"next/navigation\";\n5\timport { useForm } from \"react-hook-form\";\n6\timport { zodResolver } from \"@hookform/resolvers/zod\";\n7\timport { checkoutFormSchema, CheckoutFormInput } from \"@/lib/schemas/booking-schema\";\n8\timport { Hotel } from \"@/lib/types\";\n9\timport { formatPrice, formatShortDate } from \"@/lib/utils/format\";\n10\timport { Loader2, Lock, CreditCard } from \"lucide-react\";\n11\t\n12\tinterface CheckoutFormProps {\n13\t  hotel: Hotel;\n14\t  checkIn: string;\n15\t  checkOut: string;\n16\t  guests: number;\n17\t  nights: number;\n18\t  totalPrice: number;\n19\t}\n20\t\n21\texport function CheckoutForm({ hotel, checkIn, checkOut, guests, nights, totalPrice }: CheckoutFormProps) {\n22\t  const router = useRouter();\n23\t  const [submitError, setSubmitError] = useState(\"\");\n24\t\n25\t  const {\n26\t    register,\n27\t    handleSubmit,\n28\t    formState: { errors, isSubmitting },\n29\t  } = useForm<CheckoutFormInput>({\n30\t    resolver: zodResolver(checkoutFormSchema),\n31\t    defaultValues: {\n32\t      guestName: \"\",\n33\t      guestEmail: \"\",\n34\t      cardNumber: \"\",\n35\t      cardExpiry: \"\",\n36\t      cardCvc: \"\",\n37\t    },\n38\t  });\n39\t\n40\t  const onSubmit = async (data: CheckoutFormInput) => {\n41\t    setSubmitError(\"\");\n42\t    try {\n43\t      const payload = {\n44\t        ...data,\n45\t        hotelId: hotel.id,\n46\t        checkIn,\n47\t        checkOut,\n48\t        guests,\n49\t      };\n50\t      const res = await fetch(\"/api/bookings\", {\n51\t        method: \"POST\",\n52\t        headers: { \"Content-Type\": \"application/json\" },\n53\t        body: JSON.stringify(payload),\n54\t      });\n55\t      if (!res.ok) {\n56\t        const err = await res.json();\n57\t        setSubmitError(err.error ?? \"Booking failed. Please try again.\");\n58\t        return;\n59\t      }\n60\t      const booking = await res.json();\n61\t      router.push(`/checkout/confirmation/${booking.id}`);\n62\t    } catch {\n63\t      setSubmitError(\"Network error. Please try again.\");\n64\t    }\n65\t  };\n66\t\n67\t  const inputClass = (hasError: boolean) =>\n68\t    `w-full border ${hasError ? \"border-red-400\" : \"border-gray-300\"} rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500`;\n69\t\n70\t  return (\n71\t    <div className=\"grid lg:grid-cols-[1fr_380px] gap-8 items-start\">\n72\t      <form onSubmit={handleSubmit(onSubmit)} noValidate className=\"space-y-6\">\n73\t        <section>\n74\t          <h2 className=\"text-lg font-semibold text-gray-900 mb-4\">Guest information</h2>\n75\t          <div className=\"space-y-4\">\n76\t            <div>\n77\t              <label htmlFor=\"guestName\" className=\"block text-sm font-medium text-gray-700 mb-1\">\n78\t                Full name <span aria-hidden className=\"text-red-500\">*</span>\n79\t              </label>\n80\t              <input\n81\t                id=\"guestName\"\n82\t                type=\"text\"\n83\t                autoComplete=\"name\"\n84\t                {...register(\"guestName\")}\n85\t                className={inputClass(!!errors.guestName)}\n86\t                aria-invalid={!!errors.guestName}\n87\t                aria-describedby={errors.guestName ? \"name-error\" : undefined}\n88\t              />\n89\t              {errors.guestName && (\n90\t                <p id=\"name-error\" role=\"alert\" className=\"text-red-500 text-xs mt-1\">\n91\t                  {errors.guestName.message}\n92\t                </p>\n93\t              )}\n94\t            </div>\n95\t\n96\t            <div>\n97\t              <label htmlFor=\"guestEmail\" className=\"block text-sm font-medium text-gray-700 mb-1\">\n98\t                Email <span aria-hidden className=\"text-red-500\">*</span>\n99\t              </label>\n100\t              <input\n101\t                id=\"guestEmail\"\n102\t                type=\"email\"\n103\t                autoComplete=\"email\"\n104\t                {...register(\"guestEmail\")}\n105\t                className={inputClass(!!errors.guestEmail)}\n106\t                aria-invalid={!!errors.guestEmail}\n107\t                aria-describedby={errors.guestEmail ? \"email-error\" : undefined}\n108\t              />\n109\t              {errors.guestEmail && (\n110\t                <p id=\"email-error\" role=\"alert\" className=\"text-red-500 text-xs mt-1\">\n111\t                  {errors.guestEmail.message}\n112\t                </p>\n113\t              )}\n114\t            </div>\n115\t          </div>\n116\t        </section>\n117\t\n118\t        <section>\n119\t          <h2 className=\"text-lg font-semibold text-gray-900 mb-1 flex items-center gap-2\">\n120\t            <CreditCard size={20} aria-hidden />\n121\t            Payment\n122\t          </h2>\n123\t          <p className=\"text-sm text-gray-500 mb-4 flex items-center gap-1\">\n124\t            <Lock size={12} aria-hidden />\n125\t            Test mode — no real charge will be made\n126\t          </p>\n127\t          <div className=\"space-y-4\">\n128\t            <div>\n129\t              <label htmlFor=\"cardNumber\" className=\"block text-sm font-medium text-gray-700 mb-1\">\n130\t                Card number <span aria-hidden className=\"text-red-500\">*</span>\n131\t              </label>\n132\t              <input\n133\t                id=\"cardNumber\"\n134\t                type=\"text\"\n135\t                maxLength={16}\n136\t                placeholder=\"1234567890123456\"\n137\t                autoComplete=\"cc-number\"\n138\t                {...register(\"cardNumber\")}\n139\t                className={inputClass(!!errors.cardNumber)}\n140\t                aria-invalid={!!errors.cardNumber}\n141\t                aria-describedby={errors.cardNumber ? \"card-error\" : undefined}\n142\t              />\n143\t              {errors.cardNumber && (\n144\t                <p id=\"card-error\" role=\"alert\" className=\"text-red-500 text-xs mt-1\">\n145\t                  {errors.cardNumber.message}\n146\t                </p>\n147\t              )}\n148\t            </div>\n149\t\n150\t            <div className=\"grid grid-cols-2 gap-4\">\n151\t              <div>\n152\t                <label htmlFor=\"cardExpiry\" className=\"block text-sm font-medium text-gray-700 mb-1\">\n153\t                  Expiry <span aria-hidden className=\"text-red-500\">*</span>\n154\t                </label>\n155\t                <input\n156\t                  id=\"cardExpiry\"\n157\t                  type=\"text\"\n158\t                  maxLength={5}\n159\t                  placeholder=\"MM/YY\"\n160\t                  autoComplete=\"cc-exp\"\n161\t                  {...register(\"cardExpiry\")}\n162\t                  className={inputClass(!!errors.cardExpiry)}\n163\t                  aria-invalid={!!errors.cardExpiry}\n164\t                  aria-describedby={errors.cardExpiry ? \"expiry-error\" : undefined}\n165\t                />\n166\t                {errors.cardExpiry && (\n167\t                  <p id=\"expiry-error\" role=\"alert\" className=\"text-red-500 text-xs mt-1\">\n168\t                    {errors.cardExpiry.message}\n169\t                  </p>\n170\t                )}\n171\t              </div>\n172\t\n173\t              <div>\n174\t                <label htmlFor=\"cardCvc\" className=\"block text-sm font-medium text-gray-700 mb-1\">\n175\t                  CVC <span aria-hidden className=\"text-red-500\">*</span>\n176\t                </label>\n177\t                <input\n178\t                  id=\"cardCvc\"\n179\t                  type=\"text\"\n180\t                  maxLength={4}\n181\t                  placeholder=\"123\"\n182\t                  autoComplete=\"cc-csc\"\n183\t                  {...register(\"cardCvc\")}\n184\t                  className={inputClass(!!errors.cardCvc)}\n185\t                  aria-invalid={!!errors.cardCvc}\n186\t                  aria-describedby={errors.cardCvc ? \"cvc-error\" : undefined}\n187\t                />\n188\t                {errors.cardCvc && (\n189\t                  <p id=\"cvc-error\" role=\"alert\" className=\"text-red-500 text-xs mt-1\">\n190\t                    {errors.cardCvc.message}\n191\t                  </p>\n192\t                )}\n193\t              </div>\n194\t            </div>\n195\t          </div>\n196\t        </section>\n197\t\n198\t        {submitError && (\n199\t          <p role=\"alert\" className=\"text-red-500 text-sm bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n200\t            {submitError}\n201\t          </p>\n202\t        )}\n203\t\n204\t        <button\n205\t          type=\"submit\"\n206\t          disabled={isSubmitting}\n207\t          aria-busy={isSubmitting}\n208\t          className=\"w-full flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 disabled:bg-blue-400 text-white font-semibold py-3.5 rounded-xl text-base transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2\"\n209\t        >\n210\t          {isSubmitting && <Loader2 size={18} className=\"animate-spin\" aria-hidden />}\n211\t          {isSubmitting ? \"Confirming booking...\" : `Confirm booking — ${formatPrice(totalPrice)}`}\n212\t        </button>\n213\t      </form>\n214\t\n215\t      <aside className=\"border border-gray-200 rounded-2xl p-6 space-y-4 sticky top-24\">\n216\t        <div className=\"flex gap-4\">\n217\t          {hotel.photos[0] && (\n218\t            <div\n219\t              className=\"w-20 h-20 rounded-xl overflow-hidden shrink-0 bg-gray-100\"\n220\t              style={{ backgroundImage: `url(${hotel.photos[0]})`, backgroundSize: \"cover\", backgroundPosition: \"center\" }}\n221\t              role=\"img\"\n222\t              aria-label={hotel.name}\n223\t            />\n224\t          )}\n225\t          <div>\n226\t            <div className=\"text-xs text-gray-400 mb-1\">{\"★\".repeat(hotel.starRating)}</div>\n227\t            <h3 className=\"font-semibold text-gray-900 text-sm leading-snug\">{hotel.name}</h3>\n228\t            <p className=\"text-xs text-gray-500 mt-0.5\">{hotel.destination}</p>\n229\t          </div>\n230\t        </div>\n231\t\n232\t        <div className=\"border-t border-gray-100 pt-4 space-y-2 text-sm\">\n233\t          <div className=\"flex justify-between text-gray-600\">\n234\t            <span>Check-in</span>\n235\t            <span className=\"font-medium\">{formatShortDate(checkIn)}</span>\n236\t          </div>\n237\t          <div className=\"flex justify-between text-gray-600\">\n238\t            <span>Check-out</span>\n239\t            <span className=\"font-medium\">{formatShortDate(checkOut)}</span>\n240\t          </div>\n241\t          <div className=\"flex justify-between text-gray-600\">\n242\t            <span>Guests</span>\n243\t            <span className=\"font-medium\">{guests}</span>\n244\t          </div>\n245\t        </div>\n246\t\n247\t        <div className=\"border-t border-gray-100 pt-4 space-y-2 text-sm\">\n248\t          <div className=\"flex justify-between text-gray-600\">\n249\t            <span>{formatPrice(hotel.pricePerNight)} × {nights} night{nights !== 1 ? \"s\" : \"\"}</span>\n250\t            <span>{formatPrice(hotel.pricePerNight * nights)}</span>\n251\t          </div>\n252\t          <div className=\"flex justify-between font-semibold text-gray-900 text-base border-t border-gray-100 pt-2\">\n253\t            <span>Total</span>\n254\t            <span>{formatPrice(totalPrice)}</span>\n255\t          </div>\n256\t        </div>\n257\t      </aside>\n258\t    </div>\n259\t  );\n260\t}\n261\t"}]},"parent_tool_use_id":null,"session_id":"1a46cfe3-edd5-47d3-88ea-9b5bc1fd0648","uuid":"faf85271-51b7-4794-b06a-77c8386a2580","timestamp":"2026-07-02T15:23:34.572Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/rensknoors/repos/lateral-assessment/components/booking/checkout-form.tsx","content":"\"use client\";\n\nimport { useState } from \"react\";\nimport { useRouter } from \"next/navigation\";\nimport { useForm } from \"react-hook-form\";\nimport { zodResolver } from \"@hookform/resolvers/zod\";\nimport { checkoutFormSchema, CheckoutFormInput } from \"@/lib/schemas/booking-schema\";\nimport { Hotel } from \"@/lib/types\";\nimport { formatPrice, formatShortDate } from \"@/lib/utils/format\";\nimport { Loader2, Lock, CreditCard } from \"lucide-react\";\n\ninterface CheckoutFormProps {\n  hotel: Hotel;\n  checkIn: string;\n  checkOut: string;\n  guests: number;\n  nights: number;\n  totalPrice: number;\n}\n\nexport function CheckoutForm({ hotel, checkIn, checkOut, guests, nights, totalPrice }: CheckoutFormProps) {\n  const router = useRouter();\n  const [submitError, setSubmitError] = useState(\"\");\n\n  const {\n    register,\n    handleSubmit,\n    formState: { errors, isSubmitting },\n  } = useForm<CheckoutFormInput>({\n    resolver: zodResolver(checkoutFormSchema),\n    defaultValues: {\n      guestName: \"\",\n      guestEmail: \"\",\n      cardNumber: \"\",\n      cardExpiry: \"\",\n      cardCvc: \"\",\n    },\n  });\n\n  const onSubmit = async (data: CheckoutFormInput) => {\n    setSubmitError(\"\");\n    try {\n      const payload = {\n        ...data,\n        hotelId: hotel.id,\n        checkIn,\n        checkOut,\n        guests,\n      };\n      const res = await fetch(\"/api/bookings\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify(payload),\n      });\n      if (!res.ok) {\n        const err = await res.json();\n        setSubmitError(err.error ?? \"Booking failed. Please try again.\");\n        return;\n      }\n      const booking = await res.json();\n      router.push(`/checkout/confirmation/${booking.id}`);\n    } catch {\n      setSubmitError(\"Network error. Please try again.\");\n    }\n  };\n\n  const inputClass = (hasError: boolean) =>\n    `w-full border ${hasError ? \"border-red-400\" : \"border-gray-300\"} rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500`;\n\n  return (\n    <div className=\"grid lg:grid-cols-[1fr_380px] gap-8 items-start\">\n      <form onSubmit={handleSubmit(onSubmit)} noValidate className=\"space-y-6\">\n        <section>\n          <h2 className=\"text-lg font-semibold text-gray-900 mb-4\">Guest information</h2>\n          <div className=\"space-y-4\">\n            <div>\n              <label htmlFor=\"guestName\" className=\"block text-sm font-medium text-gray-700 mb-1\">\n                Full name <span aria-hidden className=\"text-red-500\">*</span>\n              </label>\n              <input\n                id=\"guestName\"\n                type=\"text\"\n                autoComplete=\"name\"\n                {...register(\"guestName\")}\n                className={inputClass(!!errors.guestName)}\n                aria-invalid={!!errors.guestName}\n                aria-describedby={errors.guestName ? \"name-error\" : undefined}\n              />\n              {errors.guestName && (\n                <p id=\"name-error\" role=\"alert\" className=\"text-red-500 text-xs mt-1\">\n                  {errors.guestName.message}\n                </p>\n              )}\n            </div>\n\n            <div>\n              <label htmlFor=\"guestEmail\" className=\"block text-sm font-medium text-gray-700 mb-1\">\n                Email <span aria-hidden className=\"text-red-500\">*</span>\n              </label>\n              <input\n                id=\"guestEmail\"\n                type=\"email\"\n                autoComplete=\"email\"\n                {...register(\"guestEmail\")}\n                className={inputClass(!!errors.guestEmail)}\n                aria-invalid={!!errors.guestEmail}\n                aria-describedby={errors.guestEmail ? \"email-error\" : undefined}\n              />\n              {errors.guestEmail && (\n                <p id=\"email-error\" role=\"alert\" className=\"text-red-500 text-xs mt-1\">\n                  {errors.guestEmail.message}\n                </p>\n              )}\n            </div>\n          </div>\n        </section>\n\n        <section>\n          <h2 className=\"text-lg font-semibold text-gray-900 mb-1 flex items-center gap-2\">\n            <CreditCard size={20} aria-hidden />\n            Payment\n          </h2>\n          <p className=\"text-sm text-gray-500 mb-4 flex items-center gap-1\">\n            <Lock size={12} aria-hidden />\n            Test mode — no real charge will be made\n          </p>\n          <div className=\"space-y-4\">\n            <div>\n              <label htmlFor=\"cardNumber\" className=\"block text-sm font-medium text-gray-700 mb-1\">\n                Card number <span aria-hidden className=\"text-red-500\">*</span>\n              </label>\n              <input\n                id=\"cardNumber\"\n                type=\"text\"\n                maxLength={16}\n                placeholder=\"1234567890123456\"\n                autoComplete=\"cc-number\"\n                {...register(\"cardNumber\")}\n                className={inputClass(!!errors.cardNumber)}\n                aria-invalid={!!errors.cardNumber}\n                aria-describedby={errors.cardNumber ? \"card-error\" : undefined}\n              />\n              {errors.cardNumber && (\n                <p id=\"card-error\" role=\"alert\" className=\"text-red-500 text-xs mt-1\">\n                  {errors.cardNumber.message}\n                </p>\n              )}\n            </div>\n\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div>\n                <label htmlFor=\"cardExpiry\" className=\"block text-sm font-medium text-gray-700 mb-1\">\n                  Expiry <span aria-hidden className=\"text-red-500\">*</span>\n                </label>\n                <input\n                  id=\"cardExpiry\"\n                  type=\"text\"\n                  maxLength={5}\n                  placeholder=\"MM/YY\"\n                  autoComplete=\"cc-exp\"\n                  {...register(\"cardExpiry\")}\n                  className={inputClass(!!errors.cardExpiry)}\n                  aria-invalid={!!errors.cardExpiry}\n                  aria-describedby={errors.cardExpiry ? \"expiry-error\" : undefined}\n                />\n                {errors.cardExpiry && (\n                  <p id=\"expiry-error\" role=\"alert\" className=\"text-red-500 text-xs mt-1\">\n                    {errors.cardExpiry.message}\n                  </p>\n                )}\n              </div>\n\n              <div>\n                <label htmlFor=\"cardCvc\" className=\"block text-sm font-medium text-gray-700 mb-1\">\n                  CVC <span aria-hidden className=\"text-red-500\">*</span>\n                </label>\n                <input\n                  id=\"cardCvc\"\n                  type=\"text\"\n                  maxLength={4}\n                  placeholder=\"123\"\n                  autoComplete=\"cc-csc\"\n                  {...register(\"cardCvc\")}\n                  className={inputClass(!!errors.cardCvc)}\n                  aria-invalid={!!errors.cardCvc}\n                  aria-describedby={errors.cardCvc ? \"cvc-error\" : undefined}\n                />\n                {errors.cardCvc && (\n                  <p id=\"cvc-error\" role=\"alert\" className=\"text-red-500 text-xs mt-1\">\n                    {errors.cardCvc.message}\n                  </p>\n                )}\n              </div>\n            </div>\n          </div>\n        </section>\n\n        {submitError && (\n          <p role=\"alert\" className=\"text-red-500 text-sm bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n            {submitError}\n          </p>\n        )}\n\n        <button\n          type=\"submit\"\n          disabled={isSubmitting}\n          aria-busy={isSubmitting}\n          className=\"w-full flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 disabled:bg-blue-400 text-white font-semibold py-3.5 rounded-xl text-base transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2\"\n        >\n          {isSubmitting && <Loader2 size={18} className=\"animate-spin\" aria-hidden />}\n          {isSubmitting ? \"Confirming booking...\" : `Confirm booking — ${formatPrice(totalPrice)}`}\n        </button>\n      </form>\n\n      <aside className=\"border border-gray-200 rounded-2xl p-6 space-y-4 sticky top-24\">\n        <div className=\"flex gap-4\">\n          {hotel.photos[0] && (\n            <div\n              className=\"w-20 h-20 rounded-xl overflow-hidden shrink-0 bg-gray-100\"\n              style={{ backgroundImage: `url(${hotel.photos[0]})`, backgroundSize: \"cover\", backgroundPosition: \"center\" }}\n              role=\"img\"\n              aria-label={hotel.name}\n            />\n          )}\n          <div>\n            <div className=\"text-xs text-gray-400 mb-1\">{\"★\".repeat(hotel.starRating)}</div>\n            <h3 className=\"font-semibold text-gray-900 text-sm leading-snug\">{hotel.name}</h3>\n            <p className=\"text-xs text-gray-500 mt-0.5\">{hotel.destination}</p>\n          </div>\n        </div>\n\n        <div className=\"border-t border-gray-100 pt-4 space-y-2 text-sm\">\n          <div className=\"flex justify-between text-gray-600\">\n            <span>Check-in</span>\n            <span className=\"font-medium\">{formatShortDate(checkIn)}</span>\n          </div>\n          <div className=\"flex justify-between text-gray-600\">\n            <span>Check-out</span>\n            <span className=\"font-medium\">{formatShortDate(checkOut)}</span>\n          </div>\n          <div className=\"flex justify-between text-gray-600\">\n            <span>Guests</span>\n            <span className=\"font-medium\">{guests}</span>\n          </div>\n        </div>\n\n        <div className=\"border-t border-gray-100 pt-4 space-y-2 text-sm\">\n          <div className=\"flex justify-between text-gray-600\">\n            <span>{formatPrice(hotel.pricePerNight)} × {nights} night{nights !== 1 ? \"s\" : \"\"}</span>\n            <span>{formatPrice(hotel.pricePerNight * nights)}</span>\n          </div>\n          <div className=\"flex justify-between font-semibold text-gray-900 text-base border-t border-gray-100 pt-2\">\n            <span>Total</span>\n            <span>{formatPrice(totalPrice)}</span>\n          </div>\n        </div>\n      </aside>\n    </div>\n  );\n}\n","numLines":261,"startLine":1,"totalLines":261}}}
