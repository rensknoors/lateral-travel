ext-gray-700 leading-relaxed\">{review.text}</p>\n44\t        </article>\n45\t      ))}\n46\t    </div>\n47\t  );\n48\t}\n49\t"}]},"parent_tool_use_id":null,"session_id":"1a46cfe3-edd5-47d3-88ea-9b5bc1fd0648","uuid":"60ed1649-6b41-4267-9a4c-afab091821a4","timestamp":"2026-07-02T15:23:39.824Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/rensknoors/repos/lateral-assessment/components/reviews/review-list.tsx","content":"import { Review } from \"@/lib/types\";\nimport { StarRating } from \"@/components/shared/star-rating\";\nimport { formatDate } from \"@/lib/utils/format\";\nimport { EmptyState } from \"@/components/shared/empty-state\";\nimport { MessageSquare } from \"lucide-react\";\n\ninterface ReviewListProps {\n  reviews: Review[];\n}\n\nexport function ReviewList({ reviews }: ReviewListProps) {\n  if (reviews.length === 0) {\n    return (\n      <EmptyState\n        icon={<MessageSquare size={40} />}\n        title=\"No reviews yet\"\n        description=\"Be the first to share your experience at this hotel!\"\n      />\n    );\n  }\n\n  return (\n    <div className=\"space-y-4\" aria-label=\"Guest reviews\" role=\"list\">\n      {reviews.map((review) => (\n        <article key={review.id} role=\"listitem\" className=\"border-b border-gray-100 pb-4 last:border-b-0\">\n          <div className=\"flex items-start justify-between mb-2\">\n            <div className=\"flex items-center gap-2\">\n              <div\n                className=\"w-8 h-8 rounded-full bg-blue-100 text-blue-700 font-semibold text-sm flex items-center justify-center\"\n                aria-hidden\n              >\n                {review.guestName[0].toUpperCase()}\n              </div>\n              <div>\n                <div className=\"font-medium text-gray-900 text-sm\">{review.guestName}</div>\n                <time className=\"text-xs text-gray-400\" dateTime={review.createdAt}>\n                  {formatDate(review.createdAt)}\n                </time>\n            