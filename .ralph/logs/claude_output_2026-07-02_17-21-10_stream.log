{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QjDa1uoKk3JrV9n7W5BDN8","type":"tool_result","content":"The file /Users/rensknoors/repos/lateral-assessment/components/shared/star-rating.tsx has been updated successfully. (file state is current in your context — no need to Read it back)"}]},"parent_tool_use_id":null,"session_id":"1a46cfe3-edd5-47d3-88ea-9b5bc1fd0648","uuid":"16ec910c-1221-49f7-a2aa-775aff551b2c","timestamp":"2026-07-02T15:25:30.760Z","tool_use_result":{"filePath":"/Users/rensknoors/repos/lateral-assessment/components/shared/star-rating.tsx","oldString":"\"use client\";\n\nimport { Star } from \"lucide-react\";","newString":"import { Star } from \"lucide-react\";","originalFile":"\"use client\";\n\nimport { Star } from \"lucide-react\";\n\ninterface StarRatingProps {\n  rating: number;\n  max?: number;\n  size?: number;\n}\n\nexport function StarRating({ rating, max = 5, size = 16 }: StarRatingProps) {\n  return (\n    <div className=\"flex items-center gap-0.5\" aria-label={`${rating} out of ${max} stars`}>\n      {Array.from({ length: max }, (_, i) => {\n        const filled = i < Math.floor(rating);\n        const partial = !filled && i < rating;\n        return (\n          <span key={i} className=\"relative inline-block\" style={{ width: size, height: size }}>\n            <Star\n              size={size}\n              className=\"text-gray-200 fill-gray-200\"\n              aria-hidden\n            />\n            {(filled || partial) && (\n              <span\n                className=\"absolute inset-0 overflow-hidden\"\n                style={{ width: partial ? `${(rating % 1) * 100}%` : \"100%\" }}\n              >\n                <Star size={size} className=\"text-amber-400 fill-amber-400\" aria-hidden />\n              </span>\n            )}\n          </span>\n        );\n      })}\n    </div>\n  );\n}\n","structuredPatch":[{"oldStart":1,"oldLines":5,"newStart":1,"newLines":3,"lines":["-\"use client\";","-"," import { Star } from \"lucide-react\";"," "," interface StarRatingProps {"]}],"userModified":false,"replaceAll":false}}
