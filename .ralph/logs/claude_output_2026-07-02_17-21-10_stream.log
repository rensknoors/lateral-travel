{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LsH6WYESJDaKnvB3mwgy1v","type":"tool_result","content":"1\timport hotelsData from \"@/data/hotels.json\";\n2\timport reviewsData from \"@/data/reviews.json\";\n3\timport { Hotel, Review, SearchQuery } from \"./types\";\n4\t\n5\tconst hotels: Hotel[] = hotelsData as Hotel[];\n6\tconst reviews: Review[] = reviewsData as Review[];\n7\t\n8\texport function getHotels(query: SearchQuery = {}): { data: Hotel[]; total: number } {\n9\t  let result = [...hotels];\n10\t\n11\t  if (query.destination && query.destination.trim()) {\n12\t    const dest = query.destination.toLowerCase().trim();\n13\t    result = result.filter((h) => h.destination.toLowerCase().includes(dest));\n14\t  }\n15\t\n16\t  if (query.guests) {\n17\t    result = result.filter((h) => h.maxGuests >= query.guests!);\n18\t  }\n19\t\n20\t  if (query.minPrice !== undefined) {\n21\t    result = result.filter((h) => h.pricePerNight >= query.minPrice!);\n22\t  }\n23\t\n24\t  if (query.maxPrice !== undefined) {\n25\t    result = result.filter((h) => h.pricePerNight <= query.maxPrice!);\n26\t  }\n27\t\n28\t  if (query.minRating !== undefined) {\n29\t    result = result.filter((h) => h.averageRating >= query.minRating!);\n30\t  }\n31\t\n32\t  if (query.amenities && query.amenities.length > 0) {\n33\t    result = result.filter((h) =>\n34\t      query.amenities!.every((a) => h.amenities.includes(a))\n35\t    );\n36\t  }\n37\t\n38\t  if (query.sort === \"price_asc\") {\n39\t    result.sort((a, b) => a.pricePerNight - b.pricePerNight);\n40\t  } else if (query.sort === \"price_desc\") {\n41\t    result.sort((a, b) => b.pricePerNight - a.pricePerNight);\n42\t  } else if (query.sort === \"rating_desc\") {\n43\t    result.sort((a, b) => b.averageRating - a.averageRating);\n44\t  }\n45\t\n46\t  return { data: result, total: result.length };\n47\t}\n48\t\n49\texport function getHotelById(id: string): Hotel | undefined {\n50\t  return hotels.find((h) => h.id === id);\n51\t}\n52\t\n53\texport function getReviewsByHotelId(hotelId: string): { data: Review[]; total: number } {\n54\t  const data = reviews\n55\t    .filter((r) => r.hotelId === hotelId)\n56\t    .sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime());\n57\t  return { data, total: data.length };\n58\t}\n59\t\n60\texport function addReview(hotelId: string, input: { guestName: string; rating: number; text: string }): Review {\n61\t  const review: Review = {\n62\t    id: `r${Date.now()}`,\n63\t    hotelId,\n64\t    guestName: input.guestName,\n65\t    rating: input.rating,\n66\t    text: input.text,\n67\t    createdAt: new Date().toISOString(),\n68\t  };\n69\t  reviews.push(review);\n70\t\n71\t  const hotel = hotels.find((h) => h.id === hotelId);\n72\t  if (hotel) {\n73\t    const hotelReviews = reviews.filter((r) => r.hotelId === hotelId);\n74\t    hotel.reviewCount = hotelReviews.length;\n75\t    hotel.averageRating = Math.round(\n76\t      (hotelReviews.reduce((sum, r) => sum + r.rating, 0) / hotelReviews.length) * 10\n77\t    ) / 10;\n78\t  }\n79\t\n80\t  return review;\n81\t}\n82\t\n83\texport function computeAvailability(\n84\t  hotelId: string,\n85\t  checkIn: string,\n86\t  checkOut: string,\n87\t  guests: number\n88\t): { available: boolean; nights: number; pricePerNight: number; totalPrice: number } | null {\n89\t  const hotel = hotels.find((h) => h.id === hotelId);\n90\t  if (!hotel) return null;\n91\t\n92\t  const checkInDate = new Date(checkIn);\n93\t  const checkOutDate = new Date(checkOut);\n94\t  const nights = Math.round((checkOutDate.getTime() - checkInDate.getTime()) / (1000 * 60 * 60 * 24));\n95\t\n96\t  const available = nights > 0 && guests >= 1 && guests <= hotel.maxGuests;\n97\t\n98\t  return {\n99\t    available,\n100\t    nights,\n101\t    pricePerNight: hotel.pricePerNight,\n102\t    totalPrice: available ? hotel.pricePerNight * nights : 0,\n103\t  };\n104\t}\n105\t"}]},"parent_tool_use_id":null,"session_id":"1a46cfe3-edd5-47d3-88ea-9b5bc1fd0648","uuid":"e93c4b07-2643-4a90-908d-4bdc5b74d92d","timestamp":"2026-07-02T15:24:14.579Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/rensknoors/repos/lateral-assessment/lib/hotels.ts","content":"import hotelsData from \"@/data/hotels.json\";\nimport reviewsData from \"@/data/reviews.json\";\nimport { Hotel, Review, SearchQuery } from \"./types\";\n\nconst hotels: Hotel[] = hotelsData as Hotel[];\nconst reviews: Review[] = reviewsData as Review[];\n\nexport function getHotels(query: SearchQuery = {}): { data: Hotel[]; total: number } {\n  let result = [...hotels];\n\n  if (query.destination && query.destination.trim()) {\n    const dest = query.destination.toLowerCase().trim();\n    result = result.filter((h) => h.destination.toLowerCase().includes(dest));\n  }\n\n  if (query.guests) {\n    result = result.filter((h) => h.maxGuests >= query.guests!);\n  }\n\n  if (query.minPrice !== undefined) {\n    result = result.filter((h) => h.pricePerNight >= query.minPrice!);\n  }\n\n  if (query.maxPrice !== undefined) {\n    result = result.filter((h) => h.pricePerNight <= query.maxPrice!);\n  }\n\n  if (query.minRating !== undefined) {\n    result = result.filter((h) => h.averageRating >= query.minRating!);\n  }\n\n  if (query.amenities && query.amenities.length > 0) {\n    result = result.filter((h) =>\n      query.amenities!.every((a) => h.amenities.includes(a))\n    );\n  }\n\n  if (query.sort === \"price_asc\") {\n    result.sort((a, b) => a.pricePerNight - b.pricePerNight);\n  } else if (query.sort === \"price_desc\") {\n    result.sort((a, b) => b.pricePerNight - a.pricePerNight);\n  } else if (query.sort === \"rating_desc\") {\n    result.sort((a, b) => b.averageRating - a.averageRating);\n  }\n\n  return { data: result, total: result.length };\n}\n\nexport function getHotelById(id: string): Hotel | undefined {\n  return hotels.find((h) => h.id === id);\n}\n\nexport function getReviewsByHotelId(hotelId: string): { data: Review[]; total: number } {\n  const data = reviews\n    .filter((r) => r.hotelId === hotelId)\n    .sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime());\n  return { data, total: data.length };\n}\n\nexport function addReview(hotelId: string, input: { guestName: string; rating: number; text: string }): Review {\n  const review: Review = {\n    id: `r${Date.now()}`,\n    hotelId,\n    guestName: input.guestName,\n    rating: input.rating,\n    text: input.text,\n    createdAt: new Date().toISOString(),\n  };\n  reviews.push(review);\n\n  const hotel = hotels.find((h) => h.id === hotelId);\n  if (hotel) {\n    const hotelReviews = reviews.filter((r) => r.hotelId === hotelId);\n    hotel.reviewCount = hotelReviews.length;\n    hotel.averageRating = Math.round(\n      (hotelReviews.reduce((sum, r) => sum + r.rating, 0) / hotelReviews.length) * 10\n    ) / 10;\n  }\n\n  return review;\n}\n\nexport function computeAvailability(\n  hotelId: string,\n  checkIn: string,\n  checkOut: string,\n  guests: number\n): { available: boolean; nights: number; pricePerNight: number; totalPrice: number } | null {\n  const hotel = hotels.find((h) => h.id === hotelId);\n  if (!hotel) return null;\n\n  const checkInDate = new Date(checkIn);\n  const checkOutDate = new Date(checkOut);\n  const nights = Math.round((checkOutDate.getTime() - checkInDate.getTime()) / (1000 * 60 * 60 * 24));\n\n  const available = nights > 0 && guests >= 1 && guests <= hotel.maxGuests;\n\n  return {\n    available,\n    nights,\n    pricePerNight: hotel.pricePerNight,\n    totalPrice: available ? hotel.pricePerNight * nights : 0,\n  };\n}\n","numLines":105,"startLine":1,"totalLines":105}}}
