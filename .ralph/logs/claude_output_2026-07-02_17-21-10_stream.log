{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TjVGn81nrgCj6hUHCZUknQ","type":"tool_result","content":"1\t\"use client\";\n2\t\n3\timport { Star } from \"lucide-react\";\n4\t\n5\tinterface StarRatingProps {\n6\t  rating: number;\n7\t  max?: number;\n8\t  size?: number;\n9\t}\n10\t\n11\texport function StarRating({ rating, max = 5, size = 16 }: StarRatingProps) {\n12\t  return (\n13\t    <div className=\"flex items-center gap-0.5\" aria-label={`${rating} out of ${max} stars`}>\n14\t      {Array.from({ length: max }, (_, i) => {\n15\t        const filled = i < Math.floor(rating);\n16\t        const partial = !filled && i < rating;\n17\t        return (\n18\t          <span key={i} className=\"relative inline-block\" style={{ width: size, height: size }}>\n19\t            <Star\n20\t              size={size}\n21\t              className=\"text-gray-200 fill-gray-200\"\n22\t              aria-hidden\n23\t            />\n24\t            {(filled || partial) && (\n25\t              <span\n26\t                className=\"absolute inset-0 overflow-hidden\"\n27\t                style={{ width: partial ? `${(rating % 1) * 100}%` : \"100%\" }}\n28\t              >\n29\t                <Star size={size} className=\"text-amber-400 fill-amber-400\" aria-hidden />\n30\t              </span>\n31\t            )}\n32\t          </span>\n33\t        );\n34\t      })}\n35\t    </div>\n36\t  );\n37\t}\n38\t"}]},"parent_tool_use_id":null,"session_id":"1a46cfe3-edd5-47d3-88ea-9b5bc1fd0648","uuid":"283f3fd6-aeef-4773-aae8-1fcdabdcddb0","timestamp":"2026-07-02T15:23:39.826Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/rensknoors/repos/lateral-assessment/components/shared/star-rating.tsx","content":"\"use client\";\n\nimport { Star } from \"lucide-react\";\n\ninterface StarRatingProps {\n  rating: number;\n  max?: number;\n  size?: number;\n}\n\nexport function StarRating({ rating, max = 5, size = 16 }: StarRatingProps) {\n  return (\n    <div className=\"flex items-center gap-0.5\" aria-label={`${rating} out of ${max} stars`}>\n      {Array.from({ length: max }, (_, i) => {\n        const filled = i < Math.floor(rating);\n        const partial = !filled && i < rating;\n        return (\n          <span key={i} className=\"relative inline-block\" style={{ width: size, height: size }}>\n            <Star\n              size={size}\n              className=\"text-gray-200 fill-gray-200\"\n              aria-hidden\n            />\n            {(filled || partial) && (\n              <span\n                className=\"absolute inset-0 overflow-hidden\"\n                style={{ width: partial ? `${(rating % 1) * 100}%` : \"100%\" }}\n              >\n                <Star size={size} className=\"text-amber-400 fill-amber-400\" aria-hidden />\n              </span>\n            )}\n          </span>\n        );\n      })}\n    </div>\n  );\n}\n","numLines":38,"startLine":1,"totalLines":38}}}
